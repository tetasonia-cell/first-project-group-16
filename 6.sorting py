# Time Complexity:
# Bubble Sort: O(n²)
# Insertion Sort: O(n²)

# Original array
numbers = [64, 34, 25, 12, 22, 11, 90]

print("Original Array:")
print(numbers)

# ------------------------
# Bubble Sort (with trace)
# ------------------------

bubble = numbers.copy()

print("\nBubble Sort Trace:")

for i in range(len(bubble) - 1):

    for j in range(len(bubble) - 1 - i):

        if bubble[j] > bubble[j + 1]:
            bubble[j], bubble[j + 1] = bubble[j + 1], bubble[j]

    print(f"After Pass {i + 1}: {bubble}")

print("\nBubble Sorted Array:")
print(bubble)

# ------------------------
# Insertion Sort
# ------------------------

insertion = numbers.copy()

for i in range(1, len(insertion)):

    key = insertion[i]
    j = i - 1

    while j >= 0 and insertion[j] > key:
        insertion[j + 1] = insertion[j]
        j -= 1

    insertion[j + 1] = key

print("\nInsertion Sorted Array:")
print(insertion)
